#!/usr/bin/env bash
#
# Pre-commit hook: runs Spotless on staged Java files in server/
#

# Get staged Java files (only added/modified, not deleted)
STAGED_JAVA_FILES=$(git diff --cached --name-only --diff-filter=d | grep '^server/.*\.java$')

if [ -z "$STAGED_JAVA_FILES" ]; then
    exit 0
fi

echo "Running Spotless on staged Java files..."

cd server || exit 1

./gradlew spotlessApply -q 2>/dev/null

if [ $? -ne 0 ]; then
    echo "Spotless apply failed. Please fix the issues and try again."
    exit 1
fi

cd ..

# Re-stage the formatted files
for FILE in $STAGED_JAVA_FILES; do
    if [ -f "$FILE" ]; then
        git add "$FILE"
    fi
done
